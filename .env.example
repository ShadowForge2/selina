# ==========================================
# CPBloomFX BOT ENVIRONMENT CONFIGURATION
# ==========================================

# Telegram Bot Token (Get from @BotFather)
BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN

# Express Server Port (For Web Dashboard & Render Keep-Alive)
PORT=5000

# MongoDB Connection String (Atlas or Local)
# Example: mongodb+srv://username:password@cluster.mongodb.net/cpbloomfx
DATABASE_URL=mongodb://localhost:27017/cpbloomfx

# Administrative Accounts (Comma-separated Telegram User IDs)
# Check @userinfobot to find your ID
ADMIN_IDS=123456789,987654321

# Channel ID for Auto-Posting (Must add bot as admin in channel first)
# Format: -100xxxxxxxxxx
CHANNEL_ID=-1001234567890

# Official Community & Business Links
SUPPORT_LINK=https://t.me/CPBloomFXSupport
CHANNEL_LINK=https://t.me/CPBloomFXChannel
WEBSITE_LINK=https://cpbloomfx.com
CONTACT_ADMIN_LINK=https://t.me/CPBloomFXAdmin

# Moderation Configurations
# Timeout in milliseconds for Verification (e.g., 120000 = 2 minutes)
VERIFICATION_TIMEOUT_MS=120000

# Maximum number of warnings before an automated mute/ban
WARN_LIMIT=3

# Optional: Gemini AI API Key for Natural Language auto replies
# If omitted, the bot will use high-performance local keyword/FAQ matchers
GEMINI_API_KEY=

# Telegram Post Link for App Download Instructions
POST_LINK=https://t.me/cpbloomfxofficialtelegram/5
